# ==========================================
# SOLVIQ UI — Environment template
# ==========================================
# Copy to `.env.local` or `.env` and fill in real values. Never commit secrets.

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002
NEXT_PUBLIC_API_KEY=your_api_key

# Authentication (NextAuth)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# OpenAI (client-side AI features, if used)
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_key

# AWS (if needed client-side)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=your_s3_bucket

# Payment Integration (PayU / checkout UI)
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your_payment_key

# Environment
NEXT_PUBLIC_ENV=development
